# =============================================
# BolãoCopa — Environment Variables
# Copy this file to .env.local for development
# and configure GitHub Secrets for production
# =============================================

# App Configuration
VITE_APP_NAME=BolãoCopa
VITE_APP_YEAR=2026
VITE_BASE_URL=https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPO_NAME

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# VAPID Keys for Push Notifications
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# OpenAI — for AI comic commentary and stories (Seu Zé)
# Get from https://platform.openai.com/api-keys
# ⚠️  NEVER expose this in frontend code — Supabase Edge Function secret only
OPENAI_API_KEY=your_openai_api_key_here

# Football Data API — for automatic match result sync
# Get free key from https://www.football-data.org/client/register
# ⚠️  Used only in the sync-resultados Edge Function, not in frontend
VITE_FOOTBALL_API_KEY=your_football_data_api_key_here

# ---- NEVER commit these to git ----
# Used only in scripts/ (never imported in frontend code)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_REF=your_project_ref_here
SUPABASE_DB_PASSWORD=your_db_password_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
GITHUB_REPO=YOUR_USERNAME/YOUR_REPO_NAME
