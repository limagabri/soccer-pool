# =============================================
# Soccer Pool — Environment Variables
# Copy this file to .env.local for development
# and configure GitHub Secrets for production.
# Run: cp .env.example .env.local && npm run setup
# =============================================

# App Configuration (customize for your tournament)
VITE_APP_NAME=BolãoCopa
VITE_APP_YEAR=2026
VITE_BASE_URL=https://YOUR_GITHUB_USERNAME.github.io/soccer-pool

# GitHub repo (used by npm run setup to configure GitHub Secrets automatically)
GITHUB_REPO=YOUR_USERNAME/soccer-pool

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# VAPID Keys for Web Push Notifications
# Auto-generated by: npm run setup (or: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# OpenAI — AI comic commentary and stories
# Get from https://platform.openai.com/api-keys
# NEVER expose in frontend — Supabase Edge Function secret only
OPENAI_API_KEY=your_openai_api_key_here

# Football Data API — automatic match result sync
# Free key from https://www.football-data.org/client/register
VITE_FOOTBALL_API_KEY=your_football_data_api_key_here

# ── NEVER commit the variables below to git ──────────────────────────────────
# Used only in scripts/ (npm run setup, npm run migrate) — never imported by frontend

# Supabase service role key (admin operations)
# Get from: Supabase Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase project ref (the part before .supabase.co in your URL)
SUPABASE_PROJECT_REF=your_project_ref_here

# Supabase database password (set when you created the project)
SUPABASE_DB_PASSWORD=your_db_password_here

# Full database URL for migrations — used by npm run migrate and CI/CD
# Format: postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Leave blank to build from SUPABASE_PROJECT_REF + SUPABASE_DB_PASSWORD above.
SUPABASE_DB_URL=
